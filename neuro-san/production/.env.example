# =============================================================================
# Neuro San — productie-configuratie.  Kopieer dit bestand naar  .env  en vul in.
# (.env staat in .gitignore — deel het NOOIT en commit het niet.)
# Hoe je elke waarde ophaalt staat in INRICHTEN.md
# =============================================================================

# ---- 1. META (Marketing API) ------------------------------------------------
META_ACCESS_TOKEN=                 # System User token (nooit verlopend) uit Business Manager
META_AD_ACCOUNT_ID=                # bijv. 1234567890  (ZONDER 'act_' ervoor)
META_PAGE_ID=                      # id van de Facebook-pagina waarop de ads draaien
META_API_VERSION=v21.0
META_SPECIAL_AD_CATEGORY=EMPLOYMENT   # verplicht voor vacatures — niet wijzigen
META_SPECIAL_AD_AUDIENCE_ID=       # optioneel: Special Ad Audience-id voor 'lookalike' ad sets; leeg = overslaan

# ---- 2. BEELDGENERATIE — OpenAI (gpt-image-1) ------------------------------
OPENAI_API_KEY=                    # uit platform.openai.com → API keys
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_QUALITY=high          # low / medium / high — high = realistischer/scherper

# ---- 3. E-MAIL via Resend (HTTP API — Render blokkeert SMTP) ---------------
RESEND_API_KEY=                    # uit resend.com → API Keys
RESEND_FROM=onboarding@resend.dev  # test-afzender; later eigen geverifieerd domein
APPROVAL_TO=djimon@...             # performance-marketeer die de Meta-campagne goedkeurt (Djimon)

# ---- 4. WEBHOOK / HOSTING ---------------------------------------------------
PUBLIC_BASE_URL=https://automation.tecqgroep.com   # publieke HTTPS-URL van deze service
SIGNING_SECRET=                    # lange willekeurige string (genereer: openssl rand -hex 32)
TIGRIS_SHARED_SECRET=              # geheim dat Salesforce meestuurt, ter verificatie

# ---- 5. OPTIONEEL: slimmere teksten/prompt via Claude ----------------------
# Laat leeg = deterministische templates (werkt prima). Ingevuld = AI-tekst op maat.
# Voor de VIF-keten (copy/SEO/intake-extractie) sterk aangeraden om in te vullen.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ---- 6. OPTIONEEL: Salesforce / Tigris (ATS-administrateur) -----------------
# Leeg = DRY-RUN: de VIF-keten logt de Vacatures-payload i.p.v. echt weg te schrijven.
# OAuth2 CLIENT-CREDENTIALS (server-to-server, geen wachtwoord). Connected App met
# 'Stroom met client-inloggegevens' aan + een 'Uitvoeren als'-gebruiker.
SF_LOGIN_URL=https://maintec.my.salesforce.com   # je MY DOMAIN-URL (NIET login.salesforce.com)
SF_CLIENT_ID=                      # Consumer Key van de Connected App
SF_CLIENT_SECRET=                  # Consumer Secret van de Connected App
SF_API_VERSION=v60.0
SF_VACANCY_OBJECT=Tigris__Vacancy__c   # API-naam van het Vacatures-object (controleer in Object Manager)
VACANCY_URL_BASE=https://www.maintec.nl/vacatures   # basis voor de vacaturepagina-URL (Meta-link)

# ---- 7. Neuro San — het draaiende AAOSA-netwerk dat de VIF verwerkt ('brein') ----
# Leeg/onbereikbaar = de VIF-keten valt terug op de eigen agents (agents.py).
NEURO_SAN_URL=http://localhost:8080   # publieke URL van je neuro-san server (lokaal of gehost)
NEURO_SAN_AGENT=generated/neuro_san_vif_to_publish_sourcing

# ---- 8. Meta lead-formulier (Instant Form) ---------------------------------
LEAD_PRIVACY_URL=https://www.maintec.nl/privacy   # privacybeleid-link in het leadformulier
LEAD_FOLLOWUP_URL=https://www.maintec.nl          # bedankt-/vervolgpagina na inzending
